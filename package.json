{
  "name": "vitatrack",
  "version": "0.0.6",
  "description": "Daily habit, vitamin, and prescription tracker",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:server": "nodemon --watch server server/index.js",
    "dev:client": "vite client --config client/vite.config.mjs",
    "build": "vite build client --config client/vite.config.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
